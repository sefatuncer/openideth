generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  INACTIVE
  RENTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  COMMERCIAL
}

enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  TERMINATED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  ETH
  USDT
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum KycDocumentType {
  PASSPORT
  ID_CARD
  DRIVERS_LICENSE
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  AGREEMENT_SIGNED
  AGREEMENT_TERMINATED
  KYC_UPDATE
  ESCROW_UPDATE
  SYSTEM
}

enum RewardReferenceType {
  PAYMENT
  KYC
  REFERRAL
  LISTING
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String
  name                String
  role                UserRole
  phone               String?
  walletAddress       String?            @unique
  avatarUrl           String?
  emailVerified       Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  properties          Property[]
  tenantAgreements    RentalAgreement[]  @relation("TenantAgreements")
  landlordAgreements  RentalAgreement[]  @relation("LandlordAgreements")
  payments            Payment[]          @relation("PayerPayments")
  receivedPayments    Payment[]          @relation("PayeePayments")
  reviews             Review[]
  notifications       Notification[]
  rewardPoints        RewardPoint[]
  kycVerification     KycVerification?
  kycReviews          KycVerification[]  @relation("KycReviewer")
  escrowResolutions   EscrowDeposit[]
  refreshTokens       RefreshToken[]

  @@map("users")
}

model Property {
  id                    String          @id @default(uuid())
  landlordId            String
  title                 String
  description           String
  propertyType          PropertyType
  address               String
  city                  String
  state                 String
  zipCode               String
  country               String
  latitude              Float?
  longitude             Float?
  bedrooms              Int
  bathrooms             Int
  area                  Float
  monthlyRent           Decimal         @db.Decimal(12, 2)
  depositAmount         Decimal         @db.Decimal(12, 2)
  amenities             String[]
  rules                 String[]
  status                PropertyStatus  @default(DRAFT)
  availableFrom         DateTime?
  isVerified            Boolean         @default(false)
  blockchainRegistryId  String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  landlord              User            @relation(fields: [landlordId], references: [id])
  images                PropertyImage[]
  agreements            RentalAgreement[]
  reviews               Review[]

  @@index([landlordId])
  @@index([status])
  @@index([city])
  @@index([city, status])
  @@index([monthlyRent])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(uuid())
  propertyId  String
  url         String
  caption     String?
  isPrimary   Boolean  @default(false)
  order       Int
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id])

  @@map("property_images")
}

model RentalAgreement {
  id                      String          @id @default(uuid())
  propertyId              String
  landlordId              String
  tenantId                String
  startDate               DateTime
  endDate                 DateTime
  monthlyRent             Decimal         @db.Decimal(12, 2)
  depositAmount           Decimal         @db.Decimal(12, 2)
  terms                   String?         @db.Text
  status                  AgreementStatus @default(DRAFT)
  landlordSignedAt        DateTime?
  tenantSignedAt          DateTime?
  landlordSignatureIp     String?
  tenantSignatureIp       String?
  documentUrl             String?
  documentHash            String?
  blockchainTxHash        String?
  blockchainAgreementId   String?
  terminatedAt            DateTime?
  terminationReason       String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  property                Property        @relation(fields: [propertyId], references: [id])
  landlord                User            @relation("LandlordAgreements", fields: [landlordId], references: [id])
  tenant                  User            @relation("TenantAgreements", fields: [tenantId], references: [id])
  payments                Payment[]
  escrowDeposits          EscrowDeposit[]

  @@index([propertyId])
  @@index([landlordId])
  @@index([tenantId])
  @@index([status])
  @@map("rental_agreements")
}

model Payment {
  id                      String        @id @default(uuid())
  agreementId             String
  payerId                 String
  payeeId                 String
  amount                  Decimal       @db.Decimal(12, 2)
  currency                String        @default("USD")
  method                  PaymentMethod
  status                  PaymentStatus @default(PENDING)
  dueDate                 DateTime
  paidAt                  DateTime?
  stripePaymentIntentId   String?
  stripeTransferId        String?
  blockchainTxHash        String?
  blockchainConfirmations Int?
  platformFee             Decimal?      @db.Decimal(12, 2)
  netAmount               Decimal?      @db.Decimal(12, 2)
  failureReason           String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  agreement               RentalAgreement @relation(fields: [agreementId], references: [id])
  payer                   User            @relation("PayerPayments", fields: [payerId], references: [id])
  payee                   User            @relation("PayeePayments", fields: [payeeId], references: [id])

  @@index([agreementId])
  @@index([payerId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

model EscrowDeposit {
  id                    String       @id @default(uuid())
  agreementId           String
  amount                Decimal      @db.Decimal(12, 2)
  currency              String       @default("USD")
  status                EscrowStatus @default(HELD)
  depositedAt           DateTime     @default(now())
  releasedAt            DateTime?
  refundedAt            DateTime?
  stripePaymentIntentId String?
  blockchainTxHash      String?
  disputeReason         String?
  disputeResolvedAt     DateTime?
  disputeResolution     String?
  resolvedById          String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  agreement             RentalAgreement @relation(fields: [agreementId], references: [id])
  resolver              User?           @relation(fields: [resolvedById], references: [id])

  @@index([agreementId])
  @@index([status])
  @@map("escrow_deposits")
}

model KycVerification {
  id                String          @id @default(uuid())
  userId            String          @unique
  status            KycStatus       @default(NOT_STARTED)
  documentType      KycDocumentType?
  documentFrontUrl  String?
  documentBackUrl   String?
  selfieUrl         String?
  rejectionReason   String?
  reviewedById      String?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id])
  reviewer          User?           @relation("KycReviewer", fields: [reviewedById], references: [id])

  @@map("kyc_verifications")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model Review {
  id          String   @id @default(uuid())
  propertyId  String
  reviewerId  String
  rating      Int
  comment     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id])
  reviewer    User     @relation(fields: [reviewerId], references: [id])

  @@unique([propertyId, reviewerId])
  @@index([propertyId])
  @@index([reviewerId])
  @@map("reviews")
}

model RewardPoint {
  id             String              @id @default(uuid())
  userId         String
  points         Int
  reason         String
  referenceType  RewardReferenceType?
  referenceId    String?
  createdAt      DateTime            @default(now())

  user           User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reward_points")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
